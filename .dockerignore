# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# sourdough local database (SQLite) — never bake the dev DB into the image
/data
*.db
*.db-shm
*.db-wal

# debug
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# env files
.env*

# typescript
*.tsbuildinfo
next-env.d.ts

# git / docker
.git
.gitignore
Dockerfile
.dockerignore
